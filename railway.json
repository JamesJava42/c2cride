{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install -g pnpm@10 && pnpm --filter api install --ignore-scripts && pnpm --filter api build",
    "watchPatterns": ["apps/api/**", "package.json", "pnpm-workspace.yaml", "pnpm-lock.yaml"]
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
